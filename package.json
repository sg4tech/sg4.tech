{
  "name": "sg4tech",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --no-lint && node scripts/postbuild-og.mjs",
    "start": "next start",
    "preview": "npm run build && serve out -l 3001",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint app tests --ext .ts,.tsx --max-warnings=0",
    "lint:css": "stylelint \"app/**/*.css\"",
    "lighthouse": "lhci autorun",
    "security:audit": "npm audit --audit-level=high",
    "security:code": "eslint app tests --ext .ts,.tsx --config eslint.security.config.mjs --max-warnings=0",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run --passWithNoTests=false",
    "knip": "knip",
    "optimize:svg": "svgo --multipass public/brand/logo.svg",
    "depcruise": "depcruise --config .dependency-cruiser.cjs app",
    "check": "npm run lint && npm run security:audit && npm run security:code && npm run typecheck && npm run test && npm run knip && npm run depcruise && npm run build"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^16.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^15.5.15",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "serve": "^14.2.6",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "svgo": "^4.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "tmp": "^0.2.7"
  }
}
